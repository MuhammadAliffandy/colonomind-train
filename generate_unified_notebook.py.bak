"""# --- 1. DATASET CONFIGURATION ---
# Choose which dataset to evaluate: 'NTUH', 'LIMUC', or 'TMC-UCM'
DATASET_CHOICE = 'NTUH'

# Define paths based on choice
if DATASET_CHOICE == 'NTUH':
    TRAIN_DIR = '../Dataset+Code/MES_Colonoscopy Public Dataset'
    SPLIT_CSV = '../Dataset_patient_split/Combined_Dataset_patient_split.csv'
elif DATASET_CHOICE == 'LIMUC':
